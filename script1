        statsLabels.fps.Text = "FPS: " .. fpsValue
        statsLabels.ping.Text = "Ping: " .. pingValue .. "ms"
        statsLabels.fps.TextColor3 = fpsValue < 30 and Color3.fromRGB(255, 100, 100) or Color3.new(1,1,1)
    end
end)

